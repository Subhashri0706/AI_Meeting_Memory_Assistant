<!DOCTYPE html>
<html>

<head>
    <title>AI Meeting Memory Assistant</title>
    <link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
</head>

<body>

<div class="container">

<h1>AI Meeting Memory Assistant</h1>

<form method="POST">

<textarea
name="meeting_notes"
rows="12"
placeholder="Type your meeting notes here..."></textarea>

<br><br>

<button type="submit">
Summarize
</button>

</form>

{% if result %}

<h2>Your Meeting Notes</h2>

<p>{{ result }}</p>

{% endif %}

</div>

</body>

</html>
